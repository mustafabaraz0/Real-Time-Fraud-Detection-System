<Window x:Class="FraudDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Fraud Detection Engine - Security Operations" Height="600" Width="900"
        Background="#121212" WindowStartupLocation="CenterScreen">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🛡️ REAL-TIME SECURITY OPERATIONS CENTER (SOC)" 
                Foreground="#00FF41" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <Border Grid.Row="1" BorderBrush="#333333" BorderThickness="2" CornerRadius="5" Background="#1E1E1E">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="🚨 RECENTLY BLOCKED THREATS &amp; FRAUDULENT TRANSACTIONS" Foreground="#FF3B30" FontWeight="Bold" Margin="10" FontSize="16"/>
                
                <ListView x:Name="AlertsList" Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="White" Margin="10">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#550000" BorderThickness="1" Background="#2A0808" Margin="0,5" Padding="10" CornerRadius="3" Width="800">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="[BLOCKED]" Foreground="#FF3B30" FontWeight="Bold" Width="80"/>
                                    <TextBlock Text="{Binding TransactionTime}" Foreground="#CCCCCC" Width="150"/>
                                    <TextBlock Text="{Binding AccountText}" Foreground="White" FontWeight="Bold" Width="120"/>
                                    <TextBlock Text="{Binding AmountText}" Foreground="#FFC107" FontWeight="Bold" Width="120"/>
                                    <TextBlock Text="{Binding Details}" Foreground="#AAAAAA" Width="220"/>
                                    <TextBlock Text="{Binding RiskText}" Foreground="#FF3B30" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <StatusBar Grid.Row="2" Background="#121212" Foreground="#00FF41" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock Text="🟢 System Online | Engine: Isolation Forest (v2) | Listening to Live Feed..."/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="TotalAlertsText" Text="Total Blocked: 0" Foreground="#FF3B30" FontWeight="Bold"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>